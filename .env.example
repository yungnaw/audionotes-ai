# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ===== User Auth (Required for production) =====
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="CHANGE-ME-TO-A-RANDOM-SECRET-AT-LEAST-32-CHARS"

# JWT token expiry in minutes (default: 7 days = 10080)
JWT_EXPIRE_MINUTES=10080

# Set to false to require invite code for registration
ALLOW_REGISTRATION=true

# Invite code (only used when ALLOW_REGISTRATION=false)
# INVITE_CODE="your-secret-invite-code"
